<UserControl x:Class="Komponenta1.InformacioniSistem.Views.TelemetrijaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
                    <Border Background="White"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="18">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBlock Text="Podaci telemetrije"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <WrapPanel>
                                    <StackPanel Width="260">
                                        <TextBlock Text="Bicikl"/>
                                        <ComboBox ItemsSource="{Binding TelemetrijaVM.Bicikli}"
                                                  SelectedItem="{Binding TelemetrijaVM.IzabraniBiciklZaTelemetriju}"/>
                                    </StackPanel>

                                    <StackPanel Width="160">
                                        <TextBlock Text="Brzina voznje"/>
                                        <TextBox Text="{Binding TelemetrijaVM.NovaBrzinaVoznje, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="160">
                                        <TextBlock Text="Puls vozaca"/>
                                        <TextBox Text="{Binding TelemetrijaVM.NoviPulsVozaca, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="160">
                                        <TextBlock Text="Stanje"/>
                                        <ComboBox ItemsSource="{Binding TelemetrijaVM.DostupnaStanja}"
                                                  SelectedItem="{Binding TelemetrijaVM.NovoStanje}"/>
                                    </StackPanel>
                                </WrapPanel>

                                <WrapPanel Margin="0,10,0,12">
                                    <Button Content="Dodaj telemetriju" Command="{Binding TelemetrijaVM.AddTelemetrijaCommand}" Style="{StaticResource SecondaryButton}"/>
                                    <Button Content="Sacuvaj izmjenu" Command="{Binding TelemetrijaVM.UpdateTelemetrijaCommand}"/>
                                </WrapPanel>

                                <TextBlock Text="{Binding TelemetrijaVM.PorukaValidacije}"
                                           Foreground="#E76F51"
                                           FontWeight="SemiBold"
                                           Margin="4,0,0,14"/>

                                <TextBlock Text="Pretraga telemetrije"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <WrapPanel>
                                    <StackPanel Width="260">
                                        <TextBlock Text="Bicikl Id"/>
                                        <TextBox Text="{Binding TelemetrijaVM.PretragaBiciklId, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="180">
                                        <TextBlock Text="Vrijeme ocitavanja"/>
                                        <TextBox Text="{Binding TelemetrijaVM.PretragaVremeOcitavanja, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="180">
                                        <TextBlock Text="Brzina voznje"/>
                                        <TextBox Text="{Binding TelemetrijaVM.PretragaBrzinaVoznje, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="180">
                                        <TextBlock Text="Puls vozaca"/>
                                        <TextBox Text="{Binding TelemetrijaVM.PretragaPulsVozaca, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Width="180">
                                        <TextBlock Text="Stanje"/>
                                        <ComboBox ItemsSource="{Binding TelemetrijaVM.DostupnaStanjaPretrage}"
                                                  SelectedItem="{Binding TelemetrijaVM.PretragaStanje}"
                                                  DisplayMemberPath="Naziv"/>
                                    </StackPanel>
                                </WrapPanel>

                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Pretrazi" Command="{Binding TelemetrijaVM.SearchTelemetrijaCommand}"/>
                                    <Button Content="Obrisi" Command="{Binding TelemetrijaVM.DeleteTelemetrijaCommand}" Style="{StaticResource DangerButton}"/>
                                    <Button Content="Simuliraj stanje" Command="{Binding TelemetrijaVM.SimulirajStanjeTelemetrijaCommand}" Style="{StaticResource WarnButton}"/>
                                    <Button Content="Ponisti" Command="{Binding TelemetrijaVM.UndoCommand}" Style="{StaticResource WarnButton}"/>
                                    <Button Content="Ponovi" Command="{Binding TelemetrijaVM.RedoCommand}" Style="{StaticResource WarnButton}"/>
                                </WrapPanel>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding TelemetrijaVM.Telemetrije}"
                                      SelectedItem="{Binding TelemetrijaVM.IzabranaTelemetrija}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bicikl Id" Binding="{Binding BiciklId}" Width="220"/>
                                    <DataGridTextColumn Header="Vrijeme ocitavanja" Binding="{Binding VremeOcitavanja}" Width="180"/>
                                    <DataGridTextColumn Header="Brzina" Binding="{Binding BrzinaVoznje}" Width="100"/>
                                    <DataGridTextColumn Header="Puls" Binding="{Binding PulsVozaca}" Width="100"/>
                                    <DataGridTextColumn Header="Stanje" Binding="{Binding Stanje}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                
</UserControl>
