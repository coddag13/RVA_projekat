<UserControl x:Class="Komponenta1.InformacioniSistem.Views.GrafikonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
                    <Border Background="White"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#FFF7EF"
                                    BorderBrush="#E8D7C3"
                                    BorderThickness="1"
                                    Padding="18"
                                    Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Raspodjela stanja voznje"
                                                   FontSize="20"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="LiveCharts2 prikaz aktivnih telemetrijskih stanja"
                                                   FontSize="13"
                                                   Opacity="0.75"
                                                   Margin="0,4,0,12"/>
                                    </StackPanel>

                                    <lvc:CartesianChart Grid.Row="1"
                                                        Series="{Binding GrafikonVM.StanjeSeries}"
                                                        XAxes="{Binding GrafikonVM.XAxes}"
                                                        YAxes="{Binding GrafikonVM.YAxes}"
                                                        DrawMarginFrame="{Binding GrafikonVM.OkvirGrafikona}"
                                                        LegendPosition="Hidden"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        MinHeight="380"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Background="#FFFFFF"
                                    BorderBrush="#E8D7C3"
                                    BorderThickness="1"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Stanje metrika"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="0,0,0,14"/>

                                    <ItemsControl ItemsSource="{Binding GrafikonVM.StatistikaStanja}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF3E7"
                                                        BorderBrush="#E8D7C3"
                                                        BorderThickness="1"
                                                        Padding="14"
                                                        Margin="0,0,0,10">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="{Binding BrojInstanci}"
                                                                   FontSize="26"
                                                                   FontWeight="Bold"
                                                                   Foreground="#2F6F73"/>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Stanje}"
                                                                       FontSize="16"
                                                                       FontWeight="Bold"/>
                                                            <TextBlock Text="instanci telemetrije"
                                                                       FontSize="12"
                                                                       Opacity="0.75"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                
</UserControl>
