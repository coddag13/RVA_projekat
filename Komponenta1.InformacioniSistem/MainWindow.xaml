<Window x:Class="Komponenta1.InformacioniSistem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Komponenta1.InformacioniSistem"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:views="clr-namespace:Komponenta1.InformacioniSistem.Views"
        mc:Ignorable="d"
        Title="Peloton Pulse"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7EF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FFDAB9"
                BorderBrush="#E8D7C3"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Peloton Pulse"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,8,0,2"/>

                    <TextBlock Text="Monitoring voznji"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F6F73"
                               Margin="0,0,0,28"/>

                    <Border Background="#FFF7EF"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Radni rezim"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Lokalna obrada podataka"
                                       FontSize="12"
                                       Opacity="0.85"/>
                            <TextBlock Text="{Binding AktivnoSkladisteTekst}"
                                       FontSize="12"
                                       Opacity="0.85"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2F6F73"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Stanje sistema"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Spreman za pracenje voznji"
                                       Foreground="White"
                                       FontSize="12"
                                       Opacity="0.9"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Podaci se cuvaju lokalno."
                               FontSize="12"
                               Opacity="0.75"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,18">
                <Button DockPanel.Dock="Right"
                        Content="Sacuvaj podatke"
                        Command="{Binding SacuvajCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="140"
                        Margin="12,8,0,0"/>

                <Button DockPanel.Dock="Right"
                        Content="Ucitaj podatke"
                        Command="{Binding UcitajCommand}"
                        MinWidth="130"
                        Margin="12,8,0,0"/>

                <StackPanel DockPanel.Dock="Right"
                            Width="120"
                            Margin="0,2,0,0">
                    <TextBlock Text="Format cuvanja"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="4,0,0,2"/>
                    <ComboBox ItemsSource="{Binding DostupniFormatiSkladista}"
                              SelectedItem="{Binding IzabraniFormatSkladista}"
                              DisplayMemberPath="Naziv"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Pregled voznji"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Operativni prikaz bicikala, telemetrije i trenutnih stanja"
                               FontSize="14"
                               Opacity="0.75"/>
                </StackPanel>
            </DockPanel>

            <TabControl Grid.Row="1">
                <TabItem Header="Bicikli">
                    <views:BicikliView/>
                </TabItem>
                <TabItem Header="Telemetrija">
                    <views:TelemetrijaView/>
                </TabItem>
                <TabItem Header="Grafikon stanja">
                    <views:GrafikonView/>
                </TabItem>
            </TabControl>
        </Grid>

        <Border Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,28,28"
                Background="#2F6F73"
                Padding="18,12"
                MinWidth="280"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="White"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
