<Window x:Class="Komponenta2.Statistika.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Komponenta 2 - Statistika" Height="600" Width="950">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Učitaj podatke iz Komponente 1"
                    Command="{Binding UcitajPodatkeCommand}"
                    Padding="10,5"
                    FontSize="14"/>
        </StackPanel>

        <!-- DataGrid sa biciklima -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding BicikliStatistike}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tim" Binding="{Binding Tim}" Width="*"/>
                <DataGridTextColumn Header="Vozač" Binding="{Binding Vozac}" Width="*"/>
                <DataGridTextColumn Header="Težina" Binding="{Binding Tezina, StringFormat=F2}" Width="80"/>
                <DataGridCheckBoxColumn Header="Sprinter" Binding="{Binding Sprinter}" Width="80"/>
                <DataGridTextColumn Header="Br. merenja" Binding="{Binding BrojMerenja}" Width="100"/>
                <DataGridTextColumn Header="Pros. brzina" Binding="{Binding ProsecnaBrzina, StringFormat=F2}" Width="100"/>
                <DataGridTextColumn Header="Pros. puls" Binding="{Binding ProsecanPuls, StringFormat=F2}" Width="100"/>
                <DataGridTextColumn Header="Max brzina" Binding="{Binding MaxBrzina, StringFormat=F2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Izbor metode -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
            <TextBlock Text="Statistička metoda:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <ComboBox ItemsSource="{Binding DostupneMetode}"
                      SelectedItem="{Binding IzabranaMetoda}"
                      DisplayMemberPath="Naziv"
                      Width="200"
                      FontSize="14"/>
            <Button Content="Izračunaj"
                    Command="{Binding IzracunajCommand}"
                    Margin="10,0,0,0"
                    Padding="15,5"
                    FontSize="14"/>
            <Button Content="Eksportuj u CSV"
                    Command="{Binding ExportCsvCommand}"
                    Margin="10,0,0,0"
                    Padding="15,5"
                    FontSize="14"/>
        </StackPanel>

        <!-- Rezultat -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="10">
            <StackPanel>
                <TextBlock Text="{Binding Rezultat.NazivMetode, StringFormat='Rezultat - {0}'}"
                           FontWeight="Bold"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding Rezultat.Stavke}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Opis}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Vrednost, StringFormat=F2}" TextAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusPoruka}"
                   Margin="0,10,0,0"
                   FontStyle="Italic"/>
    </Grid>
</Window>