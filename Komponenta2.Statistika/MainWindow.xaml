<Window x:Class="Komponenta2.Statistika.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Peloton Pulse - Statistika"
        Height="820"
        Width="1180"
        MinHeight="750"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7EF">

    <Window.Resources>
        <SolidColorBrush x:Key="BojaPozadine" Color="#FFF7EF"/>
        <SolidColorBrush x:Key="BojaKartice" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BojaPeach" Color="#FFDAB9"/>
        <SolidColorBrush x:Key="BojaTeksta" Color="#263238"/>
        <SolidColorBrush x:Key="BojaTeal" Color="#2F6F73"/>
        <SolidColorBrush x:Key="BojaSage" Color="#6B8F71"/>
        <SolidColorBrush x:Key="BojaCoral" Color="#E76F51"/>
        <SolidColorBrush x:Key="BojaAmber" Color="#F4A261"/>
        <SolidColorBrush x:Key="BojaIvica" Color="#E8D7C3"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BojaTeksta}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource BojaTeal}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BojaTeal}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BojaSage}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BojaSage}"/>
        </Style>

        <Style x:Key="WarnButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BojaAmber}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BojaAmber}"/>
            <Setter Property="Foreground" Value="#263238"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BojaIvica}"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BojaIvica}"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FFF3E7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#FFDAB9"
                BorderBrush="#E8D7C3"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="20">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Peloton Pulse"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,8,0,2"/>

                    <TextBlock Text="Statisticki centar"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#2F6F73"
                               Margin="0,0,0,28"/>

                    <Border Background="#FFF7EF"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Izvor podataka"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="WCF veza ka Komponenti 1"
                                       FontSize="12"
                                       Opacity="0.85"/>
                            <TextBlock Text="Fallback na lokalne podatke"
                                       FontSize="12"
                                       Opacity="0.85"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2F6F73"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Stanje sistema"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding StatusPoruka}"
                                       Foreground="White"
                                       FontSize="12"
                                       Opacity="0.9"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF3E7"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Statisticke metode"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Prosecni puls i razlike"
                                       FontSize="12"
                                       Opacity="0.85"/>
                            <TextBlock Text="Max brzine po biciklisti"
                                       FontSize="12"
                                       Opacity="0.85"/>
                            <TextBlock Text="Broj odustajanja"
                                       FontSize="12"
                                       Opacity="0.85"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Background="#FFF7EF"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Eksport rezultata"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Cuvanje statistike u CSV format"
                                       FontSize="12"
                                       Opacity="0.8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + dugme -->
            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <Button DockPanel.Dock="Right"
                        Content="Ucitaj podatke"
                        Command="{Binding UcitajPodatkeCommand}"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="140"
                        Margin="12,8,0,0"/>

                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Statisticka obrada"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="Pregled bicikala i izracunavanje statistickih metrika"
                               FontSize="14"
                               Opacity="0.75"/>
                </StackPanel>
            </DockPanel>

            <!-- Dictionary prikaz -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E8D7C3"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Dictionary prikaz"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding DictionaryPrikaz}"
                              MaxHeight="150"
                              VerticalScrollBarVisibility="Auto"
                              >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Period (Datum1, Datum2)" Binding="{Binding Period}" Width="200"/>
                            <DataGridTextColumn Header="Vozac" Binding="{Binding Vozac}" Width="150"/>
                            <DataGridTextColumn Header="Podaci [brzina, puls]" Binding="{Binding Podaci}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Statistike po biciklu -->
            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E8D7C3"
                    BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Text="Statistike po biciklisti"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding BicikliStatistike}"
                              MaxHeight="180"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tim" Binding="{Binding Tim}" Width="*"/>
                            <DataGridTextColumn Header="Vozac" Binding="{Binding Vozac}" Width="*"/>
                            <DataGridTextColumn Header="Br. merenja" Binding="{Binding BrojMerenja}" Width="90"/>
                            <DataGridTextColumn Header="Pros. brzina" Binding="{Binding ProsecnaBrzina, StringFormat=F2}" Width="100"/>
                            <DataGridTextColumn Header="Pros. puls" Binding="{Binding ProsecanPuls, StringFormat=F2}" Width="90"/>
                            <DataGridTextColumn Header="Max brzina" Binding="{Binding MaxBrzina, StringFormat=F2}" Width="90"/>
                            <DataGridTextColumn Header="Max puls" Binding="{Binding MaxPuls, StringFormat=F2}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Donji panel: metoda + rezultat -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.4*"/>
                </Grid.ColumnDefinitions>

                <!-- Izbor metode -->
                <Border Grid.Column="0"
                        Background="#FFF7EF"
                        BorderBrush="#E8D7C3"
                        BorderThickness="1"
                        Padding="18"
                        Margin="0,0,14,0">
                    <StackPanel>
                        <TextBlock Text="Statisticka metoda"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ComboBox ItemsSource="{Binding DostupneMetode}"
                                  SelectedItem="{Binding IzabranaMetoda}"
                                  DisplayMemberPath="Naziv"/>

                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Izracunaj"
                                    Command="{Binding IzracunajCommand}"/>
                            <Button Content="Eksportuj u CSV"
                                    Command="{Binding ExportCsvCommand}"
                                    Style="{StaticResource WarnButton}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Rezultat -->
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#E8D7C3"
                        BorderThickness="1"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="{Binding Rezultat.NazivMetode, StringFormat='Rezultat - {0}'}"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

                        <ScrollViewer MaxHeight="200"
                  VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Rezultat.Stavke}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF3E7"
                            BorderBrush="#E8D7C3"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,8">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding Vrednost, StringFormat=F2}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#2F6F73"/>
                                                <TextBlock Text="{Binding Opis}"
                                       VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>